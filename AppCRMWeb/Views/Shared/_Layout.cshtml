    <!-- Styles required by this view -->
    @RenderSection("Styles", required: false)
</head>
<body class="app header-fixed sidebar-fixed aside-menu-fixed aside-menu-hidden">

    <!-- *APP-HEADER* -->
    <partial name="_AppHeader" />
    <!-- /*APP-HEADER* -->

    <div class="app-body">
        <div class="sidebar">

            <!-- *SIDEBAR-NAV* -->
            <partial name="_SidebarNav" />
            <!-- /*SIDEBAR-NAV* -->

            <button class="sidebar-minimizer brand-minimizer" type="button"></button>
        </div>

        <!-- *MAIN CONTENT* -->
        <main class="main">

            <!-- *BREADCRUMB* -->
            <partial name="_BreadCrumb" />
            <!-- /*BREADCRUMB* -->
            <!-- *CONTAINER-FLUID* -->
            <div class="container-fluid">

                <!-- *PAGE* -->
                @RenderBody()
                <!-- /*PAGE* -->

            </div>
            <!-- /*CONTAINER-FLUID* -->

        </main>
        <!-- /*MAIN CONTENT* -->
        <!-- *ASIDE-MENU* -->
        <partial name="_AsideMenu" />
        <!-- /*ASIDE-MENU* -->

    </div>
    <footer class="app-footer">
        <span><a href="#">e-<span class="logo_agile">OneBazar</a> © 2019 creativeLabs.</span>
        <span class="ml-auto">Powered by <a href="http://marinecompliancesystem.com/">e-OneBazar</a></span>
    </footer>
    <script src="~/vendors/js/popper.min.js"></script>
    <script src="~/vendors/js/bootstrap.min.js"></script>
   @*  <script src="~/vendors/js/pace.min.js"></script> *@
    <!-- Plugins and scripts required by all views -->
    <script src="~/vendors/js/Chart.min.js"></script>
    <!-- CoreUI main scripts -->
    <script src="~/js/app.js"></script>
    <script src="~/js/jquery-ui.min.js"/>
    <!-- Plugins and scripts required by this views -->
    <!-- Custom scripts required by this view -->
    @RenderSection("Scripts", required: false)
    <script src="~/js/bootstrap.js" asp-append-version="true"></script>
    <script src="~/ToastrMessage/toastr.min.js"></script>
    <script src="~/jshelper/helper.js"></script>
    <script>
        $(function () {
            $('[data-toggle="tooltip"]').tooltip()
        });
        $(document).ready(function () {
            // create Editor from textarea HTML element with default set of tools
            $("#Description").kendoEditor({
                resizable: {
                    content: true,
                    toolbar: true
                }
            });
            $("#Notes").kendoEditor({
                resizable: {
                    content: true,
                    toolbar: true
                }
            });

                toastr.options = getToastrOptions();
                $('#toastr-success').click(function () {
                    toastr.success('This is a success notification from toastr.')
                });

                $('#toastr-info').click(function () {
                    toastr.info('This is an information notification provided by toastr.')
                });

                $('#toastr-warning').click(function () {
                    toastr.warning('This is a warning notification provided by toastr.')
                });

                $('#toastr-error').click(function () {
                    toastr.error('This is an error notification provided by toastr.')
                });
        });

        $('.defaultNumericValue').focusout(function () {
            var id = this.id
            if (id != null) {
                var inputValue = $("#" + id + "").val();
                if (inputValue == '') {
                    var assignvalue = $("#" + id + "");
                    assignvalue.val(0);
                }
            }
        });
        $('.defaultNumericValue').focus(function () {
            var id = this.id
            if (id != null) {
                var inputValue = $("#" + id + "").val();
                if (inputValue == "0") {
                    var assignvalue = $("#" + id + "");
                    assignvalue.val("");
                }
            }
        });
    </script>
</body>
</html>
