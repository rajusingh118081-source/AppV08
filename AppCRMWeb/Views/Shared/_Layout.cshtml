    <title>e-OneBazar</title>

        <!-- Bootstrap and necessary plugins -->
        <script src="~/vendors/js/jquery.min.js"></script>
        <!-- Icons -->
        <link href="~/vendors/css/font-awesome.min.css" rel="stylesheet" asp-append-version="true">
        <link href="~/vendors/css/simple-line-icons.min.css" rel="stylesheet" asp-append-version="true">
        <!-- Main styles for this application -->
        <link href="~/ToastrMessage/toastr.css" rel="stylesheet" asp-append-version="true" />
        <link href="~/ToastrMessage/toastr.min.css" rel="stylesheet" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

