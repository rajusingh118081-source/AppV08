@model AppCRMWeb.Models.DataManager
@{
    ViewData["Title"] = "Data-Manager";
    string dataManagerTitleName = string.Empty;
    bool IsScreenType = false;
    if (Model._ListData.Count() >0) {
        dataManagerTitleName = Model._ListData.FirstOrDefault().DataManagerTitle;
        IsScreenType = Model._ListData.FirstOrDefault().IsScreenType;
    }

}


<div class="row">
    <div class="col">
        <div class="card card-accent-info">
            <div class="card-header">
                <div class="row">
                    <div class="col-5"><span>@dataManagerTitleName Data Manager</span></div>
                    <div class="col-7">
                        @*asp-controller="Ref_Category" asp-action="Details" asp-route-view="Categories"*@
                        <a class="btn btn-primary borderradius" onclick="AddRow()" title="Add Record" id="added_@Model.ControllerName" data-toggle="modal" data-target="#ModalPopup_@Model.ControllerName"><i class="fa fa-plus-square"></i></a>
                        <a class="btn btn-primary borderradius" title="View Record"><i class="fa fa-eye"></i></a>
                        <a class="btn btn-primary borderradius" title="Edit Record" onclick="EditRow()" id="EditRow_@Model.ControllerName" data-toggle="modal" data-target="#ModalPopup_@Model.ControllerName"><i class="fa fa-edit"></i></a>
                        <a class="btn btn-primary borderradius" title="Delete Record" onclick="DeleteRow()" id="DeleteRow_@Model.ControllerName"><i class="fa fa-close"></i></a>
                        <a class="btn btn-primary borderradius" title="Search Record" data-toggle="modal" data-target="#exampleModalCenter"><i class="fa fa-search"></i></a>
                        <a class="btn btn-primary borderradius" title="Import Record" id="btnModalImport_@Model.ControllerName" onclick="ImportProduct()" data-toggle="modal" data-target="#ModalImport"><i class="fa fa-file-excel-o"></i></a>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="card-body">
                    <div class="col-12">
                        <table id="Table_@Model.ControllerName" class="table table-bordered table-hover" style="width:100%">
                            <thead>
                                <tr>
                                    @{
                                        foreach (var rowData in Model._ListData)
                                        {
                                                            <th>@rowData.ColumnHeading</th>
                                        }
                                    }
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ModelPopup" />
<script src="~/datamanagerjs/customjsmanage.js"></script>


<script>
    validation.init("#formStock");
    var rowID = 0;
    var IsScreenType = "@IsScreenType";
    var ControllerName = "Table_@Model.ControllerName";
    var CurrentControllerName = "@Model.ControllerName";
    function CapToLowerCase(str) {
        return str
            .replace(/^[^ ]/g, match => (match.toLowerCase()));
    }
    $(document).ready(function () {
        debugger;
        var jsonData = @Html.Raw(Json.Serialize(@Model._ListData));
        columnTable = [];
        $.each(jsonData, function (key, value) {
            var fieldName = value.fieldName;
            if (fieldName == 'ID') {
                fieldName = "id";
            }else{
                fieldName=CapToLowerCase(fieldName);
            }
            ManageColumns("@Model.ControllerName", fieldName);
            //columnTable.push({ "data": fieldName, "name": fieldName, "autoWidth": true });
        });
        //[{ "data": "id", "name": "ID", "autoWidth": true }]
        $("#" + ControllerName+"").DataTable({
            // Design Assets
            "stateSave": true,
            "processing": true,
            "serverSide": true,
            "filter": true,
            "ajax": {
                "url": '@Url.Action("LoadTable",Model.ControllerName)?refID=' + "@Model.RefID",
                "type": "POST",
                "datatype": "json"
            },
            "language": {
                "emptyTable": "No record found.",
                "processing":
                    '<i class="fa fa-spinner fa-spin fa-3x fa-fw" style="color:#2a2b2b;"></i><span class="sr-only">Loading...</span> '
            },
            "columnDefs": [{
                "targets": [0],
                "visible": false,
                "searchable": false,
            }],
            "columns": columnTable
        });
        var table = $("#" + ControllerName + "").DataTable();
        $('#' + ControllerName + ' tbody').on('click', 'tr', function () {
       var $row = $(this).closest('tr');
          var data = table.row($row).data();
           if ($(this).hasClass('selected') ) {
            $(this).removeClass('selected');
         }
         else {
            table.$('tr.selected').removeClass('selected');
            $(this).addClass('selected');
          }
            rowID = data.uniqueNumber;
            //rowID = data.encryptedID;
          LoadFuncation();
          //alert(data.id);
      });
        LoadFuncation();
    });

    function LoadFuncation() {
        if (rowID == 0) {
            $('#DeleteRow_@Model.ControllerName').addClass("Disabled");
            $("#EditRow_@Model.ControllerName").addClass("Disabled");
              //$(selector). attr('disabled', true);
          } else {
            $('#DeleteRow_@Model.ControllerName').removeClass("Disabled");
            $("#EditRow_@Model.ControllerName").removeClass("Disabled");
          }
    }
    //Add row
    function AddRow() {
        var windowURL = new URLSearchParams(window.location.search);
        var parentID = windowURL.get('UniqueNumberID');
        if (IsScreenType == "False") {
            var url = '@Url.Action("Details", Model.ControllerName)?refID=' + parentID;
            $('#ModelPartialView_@Model.ControllerName').load(url);
        } else {
            var url = '@Url.Action("Details", Model.ControllerName)?refID=' + parentID;
            window.location.replace(url);
        }
    }
    //Edit Row
    function EditRow() {
        if (rowID != null && rowID != '') {
            if (IsScreenType == "False") {
                var url = '@Url.Action("Details", Model.ControllerName)?UniqueNumberID=' + rowID;
                $('#ModelPartialView_@Model.ControllerName').load(url);
            } else {
                var url = '@Url.Action("Details", Model.ControllerName)?UniqueNumberID=' + rowID;
                window.location.replace(url);
            }
        } else {
            $.confirm({
                title: 'Edit "@dataManagerTitleName"',
                content: 'No records selected. <br/> Please highlight a record to perform this operation.',
                draggable: true,
                dragWindowGap: 0, // number of px of distance
            });
        }
    }
    //Delete Row
    function DeleteRow() {
        if (rowID > 0 && rowID != '') {
            var url = '@Url.Action("DeleteRow", Model.ControllerName)?ID=' + id;
            $.confirm({
                title: 'Delete "@dataManagerTitleName"?',
                content: 'Are you sure you want to delete this record?',
                autoClose: 'cancelAction|8000',
                draggable: true,
                buttons: {
                    deleteProduct: {
                        text: 'Delete Stock',
                        action: function () {
                            $.ajax({
                                type: "post",
                                url: url,
                            }).done(function (data) {
                                if (data.status == true) {
                                    toastr.error(data.message);
                                    $('#TableDataManager').DataTable().ajax.reload();
                                    rowID = 0;
                                    LoadFuncation();
                                } else {
                                    toastr.error(data.message);
                                }
                            }).fail(function (data) {
                                toastr.error('Internal server error');
                            });
                            event.preventDefault();
                        }
                    },
                    cancelAction: function () {
                        //$.alert('action is canceled');
                    }
                }
            });
        }
    }

   function ImportProduct() {
        var url = '@Url.Action("ImportProductDetails", "Main_Products")';
        $('#ModelPartialView').load(url);
    }
    function ImportProductsExcel() {
        var dataImage = new FormData();
        var imagefile = $("#ImportProducts")[0].files[0];
        dataImage.append("file", imagefile);
        var file = $('#ImportProducts').val();
        if (!(/\.(xlsx|xls|xlsm)$/i).test(file)) {
            console.log("Not support file:{0}" + imagefile);
            //alert('Please upload valid excel file .xlsx, .xlsm, .xls only.');
            ToggleAlert('Import Excel', 'Please upload valid excel file .xlsx, .xlsm, .xls only.')
        } else {

            $.ajax({
                url: '@Url.Action("ImportProduct", "Main_Products")',
                data: dataImage,
                processData: false,
                contentType: false,
                type: "POST",
                success: function (data) {
                    if (data.status == true) {
                        toastr.success(data.message);
                        $('#ModalImport').modal('toggle');
                        $('#TableMain_Products').DataTable().ajax.reload();
                    } else {
                        toastr.error(data.message);
                    }
                },error: function (req, status, error) {
                    console.log(msg);
                }
            });
        }
    }
</script>
<style>
    .col-form-label {
        padding-top: calc(0.0rem + 1px) !important;
        padding-bottom: calc(0.375rem + 1px);
        margin-bottom: 0;
        line-height: 1.5;
    }
</style>
