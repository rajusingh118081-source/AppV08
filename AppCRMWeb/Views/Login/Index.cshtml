@model App.Model.Sec_Users
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Account.cshtml";
}
<div class="auth-container">

    <div class="auth-card">

        <!-- Left branding -->
        <div class="auth-left">
            <h1>Welcome</h1>
            <p>Sign in to access your dashboard and manage your account.</p>
        </div>

        <!-- Right form -->
        <div class="auth-right">

            <h2>Sign In</h2>

            <form method="post" action="/Login/Login" novalidate>

                <div class="input-box">
                    <label>Email Address</label>
                    <input type="text" id="EmailAddress" name="EmailAddress" placeholder="you@example.com">
                    <span data-valmsg-for="EmailAddress" class="error"></span>
                </div>

                <div class="input-box">
                    <label>Password</label>
                    <input type="password" id="PasswordHash" name="PasswordHash" placeholder="••••••••">
                    <span data-valmsg-for="PasswordHash" class="error"></span>
                </div>

                <div class="row-flex">
                    <label><input type="checkbox"> Remember me</label>
                    <a href="/Account/ForgotPassword">Forgot?</a>
                </div>

                <button type="button" onclick="RedirectHome()" class="btn-login">
                    Sign In
                </button>

                <p class="bottom-text">
                    Don’t have an account?
                    <a href="/Account/Registers">Create one</a>
                </p>

            </form>

        </div>
            <div class="card text-white bg-primary py-5 d-md-down-none" style="width:44%">
                <div class="card-body text-center">
                    <div>
                        <h2>Sign up</h2>
                        <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
                        <a class="btn btn-primary active mt-3" asp-controller="Account" asp-action="Registers">Register Now!</a>
    </div>

</div>

<script>
    function RedirectHome() {
        window.location.href = "/Home";
    }
</script>
<style>
    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: linear-gradient(140deg, #f7f7f7, white);
        height: 100vh;
    }

    /* Center container */
    .auth-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }
</style>
<script>
    const RedirectHome = () => window.location.href = "/Home";

    /* Main card */
    .auth-card {
        width: 800px;
        display: flex;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }

    /* Left side */
    .auth-left {
        flex: 1;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: white;
        padding: 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .auth-left h1 {
            font-size: 36px;
            margin-bottom: 10px;
        }

        .auth-left p {
            opacity: 0.9;
            font-size: 14px;
            line-height: 1.5;
        }

    /* Right side */
    .auth-right {
        flex: 1;
        background: #ffffff;
        padding: 40px;
    }

        .auth-right h2 {
            margin-bottom: 25px;
        }

    /* Inputs */
    .input-box {
        margin-bottom: 18px;
    }

        .input-box label {
            display: block;
            font-size: 13px;
            margin-bottom: 6px;
            color: #333;
        }

        .input-box input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            outline: none;
        }

            .input-box input:focus {
                border-color: #3b82f6;
            }

    /* Row */
    .row-flex {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin: 10px 0 20px;
    }

        .row-flex a {
            color: #3b82f6;
            text-decoration: none;
        }

    /* Button */
    .btn-login {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: #3b82f6;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-login:hover {
            background: #2563eb;
        }

    /* Bottom text */
    .bottom-text {
        text-align: center;
        margin-top: 15px;
        font-size: 13px;
    }

        .bottom-text a {
            color: #3b82f6;
            text-decoration: none;
        }

    /* Error */
    .error {
        color: red;
        font-size: 12px;
    }

    /* ===== RESPONSIVE DESIGN ===== */

    /* Desktop default */
    .auth-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* 🔥 Hide on mobile devices */
    @@media (max-width: 768px) {
        .auth-left {
            display: none;
        }

        .auth-card {
            flex-direction: column;
            width: 95%;
        }

        .auth-right {
            width: 100%;
            padding: 25px;
        }
    }
</style>