@model App.Model.Sec_Users
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Account.cshtml";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card-group">
            <div class="card p-4">
                <form asp-controller="Login" asp-action="Login" method="post">
                    <div class="card-body">
                        <h1>Login</h1>
                        <p class="text-muted">Sign In to your account</p>
                        <div class="input-group mb-2">
                            <span class="input-group-addon"><i class="icon-user"></i></span>
                            <input asp-for="EmailAddress" type="text" class="form-control" placeholder="Email address">
                        </div>
                        <div class="input-group">
                            <span asp-validation-for="EmailAddress" class="text-danger"></span>
                        </div>
                        <br />
                        <div class="input-group mb-2">
                            <span class="input-group-addon"><i class="icon-lock"></i></span>
                            <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Password">
                        </div>
                        <div class="input-group">
                            <span asp-validation-for="PasswordHash" class="text-danger"></span>
                        </div>
                        <div asp-validation-summary="All" class="text-danger help-block"></div>
                        <div class="row">
                            <div class="col-6">
                                <button type="button" class="btn btn-primary px-4" onclick="RedirectHome()">Login</button>
                            </div>
                            <div class="col-6 text-right">
                                <a class="btn btn-link px-0" asp-controller="Account" asp-action="ForgotPassword">Forgot password?</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="card text-white bg-primary py-5 d-md-down-none" style="width:44%">
                <div class="card-body text-center">
                    <div>
                        <h2>Sign up</h2>
                        <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
                        <a class="btn btn-primary active mt-3" asp-controller="Account" asp-action="Registers">Register Now!</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
        #bodyBackground {
            background-repeat:round;
            background-image: url('/images/1.jpg');
        }
        .help-block ul {
        list-style-type: none;
    }
</style>
<script>
    const RedirectHome = () => window.location.href = "/Home";

</script>